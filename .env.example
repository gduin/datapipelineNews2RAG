# ---- Kafka (KRaft, no ZooKeeper) ----
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
KAFKA_CLIENT_ID=news-rag
KAFKA_NEWS_TOPIC=news.raw
KAFKA_PROCESSED_TOPIC=news.embedded
KAFKA_DLQ_TOPIC=news.dlq
KAFKA_CONSUMER_GROUP=flink-rag-pipeline
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_CA_LOCATION=

# ---- Schema Registry ----
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ---- Flink ----
FLINK_JOBMANAGER_RPC_ADDRESS=flink-jobmanager
FLINK_REST_PORT=8081

# ---- Vector Store (Qdrant) ----
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=news_embeddings
QDRANT_VECTOR_SIZE=768

# ---- Embeddings ----
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
OPENAI_API_KEY=

# ---- LLM (RAG) ----
# LLM_PROVIDER options:
#   openai    - call OpenAI (requires a real OPENAI_API_KEY; ignores LLM_BASE_URL if empty)
#   llamacpp  - call a llama.cpp server in OpenAI-compatible mode (requires LLM_BASE_URL)
#   stub      - no LLM at all; returns retrieved context verbatim (useful for offline dev)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
# OpenAI-compatible base URL. Required for llamacpp; optional for openai.
# For llama.cpp: http://llama-server:8080/v1
LLM_BASE_URL=

# ---- Scrapers ----
SCRAPER_USER_AGENT="NewsRAGBot/1.0 (+https://example.com/bot)"
SCRAPER_RATE_LIMIT_RPS=2
SCRAPER_HTTP_TIMEOUT=30

# ---- Observability ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOG_LEVEL=INFO
